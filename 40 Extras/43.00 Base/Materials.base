views:
  - type: table
    name: Table
    filters:
      and:
        - file.inFolder("50 Sources/52.00 Materials")
    groupBy:
      property: file.folder
      direction: ASC
    order:
      - file.name
      - file.tags
    sort:
      - property: file.path
        direction: ASC
    columnSize:
      file.name: 333
