views:
  - type: table
    name: Table
    filters:
      and:
        - file.inFolder("40 Extras/42.00 Templates")
    groupBy:
      property: file.folder
      direction: ASC
    order:
      - file.name
      - file.tags
    sort:
      - property: file.name
        direction: ASC
    columnSize:
      file.tags: 508
