views:
  - type: table
    name: Table
    filters:
      and:
        - file.inFolder("90 Spaces/92.00 School/92.40 Support Notes")
    groupBy:
      property: file.folder
      direction: ASC
    order:
      - file.name
      - file.tags
    sort:
      - property: file.name
        direction: ASC
    columnSize:
      file.name: 362
